# 后端配置文件示例
# 复制本文件为 .env 并根据需要修改

# 服务端口
PORT=8000

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=qwen2.5:7b
NUM_CTX=8192
TEMPERATURE=0.7

# Embedding 模型配置
EMBEDDING_MODEL=bge-m3

# ChromaDB 配置
CHROMA_URL=http://localhost:8001
TECH_COLLECTION=engineering_docs
STYLE_COLLECTION=style_samples

# 检索配置
TECH_RETRIEVER_K=5
STYLE_RETRIEVER_K=3
