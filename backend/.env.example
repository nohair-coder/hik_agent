# 后端配置文件示例
# 复制本文件为 .env 并根据需要修改

# 服务端口
PORT=8000

# ============================================================
# LLM 配置（OpenAI 兼容 API）
# ============================================================

# 模型名称
# OpenAI:   gpt-4o / gpt-4o-mini / gpt-3.5-turbo
# DeepSeek: deepseek-chat / deepseek-reasoner
# 阿里云:   qwen-plus / qwen-max / qwen-turbo
MODEL_NAME=deepseek-chat

# API Key（必填）
API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# API BaseURL
# OpenAI 官方:  https://api.openai.com/v1（默认）
# DeepSeek:     https://api.deepseek.com/v1
# 阿里云 Qwen:  https://dashscope.aliyuncs.com/compatible-mode/v1
API_BASE_URL=https://api.deepseek.com/v1

# 生成参数
TEMPERATURE=0.7
MAX_TOKENS=4096

# ============================================================
# Embedding 配置（OpenAI 兼容 API）
# ============================================================

# 嵌入模型名称
# OpenAI:  text-embedding-3-small / text-embedding-3-large / text-embedding-ada-002
# 阿里云:  text-embedding-v3
EMBEDDING_MODEL=text-embedding-3-small

# 嵌入 API Key（不填则复用 API_KEY）
EMBEDDING_API_KEY=

# 嵌入 API BaseURL（不填则复用 API_BASE_URL）
EMBEDDING_API_BASE_URL=

# ============================================================
# ChromaDB 配置（需要单独运行 `chroma run` 或 docker）
# ============================================================
CHROMA_URL=http://localhost:8001
TECH_COLLECTION=engineering_docs
STYLE_COLLECTION=style_samples

# ============================================================
# 检索配置
# ============================================================
TECH_RETRIEVER_K=5
STYLE_RETRIEVER_K=3
